# RAKSHAK Linux appliance — copy to linux/.env and customize

# Host LAN IP (this machine) — used in DNS answers, docs, firewall
RAKSHAK_LAN_IP=CHANGE_ME_LAN_IP

# Admin bootstrap (first run only)
RAKSHAK_ADMIN_EMAIL=admin@rakshak.lan
RAKSHAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API security (min 32 chars) — generate: openssl rand -hex 32
RAKSHAK_SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32

# Internal API (log collector) — min 16 chars — generate: openssl rand -hex 16
RAKSHAK_INTERNAL_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_16

# Database: sqlite (default) or postgres
RAKSHAK_DB_DRIVER=sqlite
RAKSHAK_DB_DSN=file:/data/rakshak.db?cache=shared&_journal_mode=WAL

# Postgres (if RAKSHAK_DB_DRIVER=postgres)
# RAKSHAK_DB_DSN=postgres://rakshak:CHANGE_ME@postgres:5432/rakshak?sslmode=disable

# DNS
RAKSHAK_DNS_PORT=53
RAKSHAK_DNS_BLOCK_IP=0.0.0.0
RAKSHAK_DNS_BLOCK_IPV6=::

# Upstream recursive (Unbound inside compose)
RAKSHAK_UPSTREAM=unbound:5353

# Logging
RAKSHAK_LOG_LEVEL=info
RAKSHAK_QUERY_LOG_RETENTION_DAYS=7

# Dashboard
NEXT_PUBLIC_API_URL=http://rakshak-api:8080
RAKSHAK_CORS_ORIGINS=http://localhost:3000,https://rakshak.lan

# TLS
RAKSHAK_DOMAIN=rakshak.lan

# Optional Redis
RAKSHAK_REDIS_URL=

# Force LAN DNS to this host (requires CAP_NET_ADMIN on Linux host)
RAKSHAK_FORCE_DNS=false

# Grafana (monitoring profile only)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
